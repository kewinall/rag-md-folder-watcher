# Linux example: /opt/rag-md-data
# Windows example: C:/rag-md-data
HOST_DATA_DIR=./data

# Local build defaults. For GHCR, set IMAGE_NAME=ghcr.io/<owner>/rag-md-folder-watcher
IMAGE_NAME=ghcr.io/kewinall/rag-md-folder-watcher
IMAGE_TAG=1.0.1
SOURCE_REPOSITORY=https://github.com/kewinall/rag-md-folder-watcher

# Linux usually uses the UID/GID of the user running Docker Compose.
# Windows Docker Desktop can keep 1000/1000.
CONTAINER_UID=1000
CONTAINER_GID=1000

POLL_INTERVAL_SECONDS=3
STABLE_CHECKS=3
WATCH_RECURSIVE=true
PROCESS_EXISTING_ON_START=true

OCR_ENABLED=true
OCR_LANG=eng+chi_tra
OCR_TIMEOUT_SEC=120
PDF_OCR_DPI=200
PDF_OCR_MAX_PAGES=100
ENABLE_LIBREOFFICE=true
LIBREOFFICE_TIMEOUT_SEC=180

MAX_FILE_MB=100
MAX_OUTPUT_CHARS=2000000
EXCEL_MAX_ROWS_PER_SHEET=5000
CSV_MAX_ROWS=10000
REMOVE_REPEATED_LINES=true

ARCHIVE_SOURCE=true
WRITE_METADATA=true
WRITE_DONE_MARKER=true
DEDUPLICATE=false
OVERWRITE_OUTPUT=false

MEM_LIMIT=4g
CPU_LIMIT=2.0
LOG_LEVEL=INFO
HEALTHCHECK_MAX_AGE_SECONDS=60
